# infra-demo runtime configuration.
# Non-secret only. Do not put credentials, tokens, or private keys here.
# Installed by provision.sh as /etc/infra-demo/infra-demo.env with mode 640
# and owner root:infra-demo.

# Python service listens only on loopback. nginx is the public HTTP entry point.
INFRA_DEMO_HOST=127.0.0.1
INFRA_DEMO_PORT=8080
INFRA_DEMO_PUBLIC_PORT=80
INFRA_DEMO_LOG_DIR=/var/log/infra-demo
